{
  "info": {
    "name": "Spingpong API",
    "description": "Colecao de endpoints da API de atletas, competicoes e jogos",
    "version": "2.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Admin\",\n  \"email\": \"admin@spingpong.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@spingpong.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Atletas",
      "item": [
        { "name": "Listar", "request": { "method": "GET", "url": "{{baseUrl}}/atletas" } },
        { "name": "Ranking", "request": { "method": "GET", "url": "{{baseUrl}}/atletas/ranking" } },
        {
          "name": "Criar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Atleta Demo\",\n  \"email\": \"atleta.demo@spingpong.com\"\n}"
            },
            "url": "{{baseUrl}}/atletas"
          }
        }
      ]
    },
    {
      "name": "Competicoes",
      "item": [
        { "name": "Listar", "request": { "method": "GET", "url": "{{baseUrl}}/competicoes" } },
        {
          "name": "Criar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Sping Open 2026\",\n  \"tipo\": \"SPING_OPEN\",\n  \"data_inicio\": \"2026-05-01\"\n}"
            },
            "url": "{{baseUrl}}/competicoes"
          }
        }
      ]
    },
    {
      "name": "Jogos",
      "item": [
        { "name": "Listar", "request": { "method": "GET", "url": "{{baseUrl}}/jogos" } },
        {
          "name": "Criar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"competicao_id\": 1,\n  \"fase\": \"GRUPOS\",\n  \"atleta_a_id\": 1,\n  \"atleta_b_id\": 2\n}"
            },
            "url": "{{baseUrl}}/jogos"
          }
        }
      ]
    }
  ]
}
